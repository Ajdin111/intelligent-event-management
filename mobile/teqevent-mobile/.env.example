# ─── TeqEvent Mobile — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit it.
#
# EXPO_PUBLIC_* variables are inlined at build time by Expo (SDK 50+).
# No extra library needed — process.env.EXPO_PUBLIC_API_URL works in RN.

# Your machine's local IP where the FastAPI backend is running.
# Find it with:
#   macOS:   ipconfig getifaddr en0
#   Windows: ipconfig (look for IPv4 address)
#
# Common values:
#   Android emulator → http://10.0.2.2:8000
#   iOS simulator    → http://localhost:8000
#   Physical device  → http://192.168.x.x:8000  (your machine's LAN IP)
EXPO_PUBLIC_API_URL=http://localhost:8000
