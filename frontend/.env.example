# Frontend environment variables
# Copy this file to .env.local and fill in values.
# Vite exposes variables prefixed with VITE_ to the browser.

# API base URL — leave as /api in development (proxied by Vite to the FastAPI backend).
# In production, set this to your deployed API URL.
VITE_API_BASE_URL=/api

# App name shown in the browser tab (also referenced in index.html directly)
VITE_APP_NAME=TeqEvent
