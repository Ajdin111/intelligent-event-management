# Database — points to Docker postgres container (do not change)
DATABASE_URL=postgresql://postgres:postgres@db:5432/event_management

# JWT — change SECRET_KEY to any long random string
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis — points to Docker redis container (do not change)
REDIS_URL=redis://redis:6379

# Email — fill in your Gmail credentials to enable email sending
# Use a Gmail App Password, not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# App (do not change)
APP_ENV=development
DEBUG=True
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE_MB=5
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
